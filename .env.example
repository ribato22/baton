# .env.example — salin ke .env dan isi (JANGAN commit .env)

# Anthropic — dipakai AnthropicProvider
ANTHROPIC_API_KEY=

# Moonshot (Kimi) — dipakai OpenAICompatProvider
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Ollama lokal — dipakai OpenAICompatProvider
OLLAMA_BASE_URL=http://localhost:11434/v1
